# -----------------------------------------------
# Fitmaster — Variables de entorno
# -----------------------------------------------
# Copia este archivo como .env.local y rellena los valores

# Resend API Key
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe ser un dominio verificado en Resend)
# Si no tienes dominio propio, Resend permite usar onboarding@resend.dev en modo test
RESEND_FROM_EMAIL=noreply@tudominio.es
